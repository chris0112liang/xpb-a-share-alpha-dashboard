# Frontend dev proxy target. Used by npm run dev.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional absolute API base for static preview/deployment builds.
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: set to 1 only if your local proxy breaks Akshare/Tencent requests.
# XPB_DISABLE_PROXY=1
